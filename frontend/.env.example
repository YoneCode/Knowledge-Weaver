# Privy app id — create one at https://dashboard.privy.io/ (free).
VITE_PRIVY_APP_ID=your-privy-app-id

# Deployed KnowledgeWeaver contract address on Bradbury.
# scripts/deploy.py fills this automatically after a successful deploy.
VITE_CONTRACT_ADDRESS=

# Landing/marketing site origin. Used by the dashboard's brand-mark
# "home" link. Defaults to "/" when not set.
VITE_LANDING_URL=
