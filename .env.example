# ── GenLayer contract deploy / test (Bradbury testnet, chain 4221) ──────────
# Your funded Bradbury account private key (hex, starts with 0x).
# Fund it at the faucet first: https://testnet-faucet.genlayer.foundation/
# NEVER commit this file. NEVER share this key.
ACCOUNT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: a second account key used by some integration tests.
ACCOUNT_PRIVATE_KEY_2=

# GenLayer network for scripts/tests (default: testnet-bradbury)
GENLAYER_NETWORK=testnet-bradbury
